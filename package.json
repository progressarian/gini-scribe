{
  "name": "gini-scribe",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "prettier --write \"src/**/*.{js,jsx,css}\" \"server/**/*.js\" \"*.{js,json}\" && concurrently -n client,server -c blue,green \"vite\" \"npm run dev --prefix server\"",
    "dev:client": "vite",
    "dev:server": "npm run dev --prefix server",
    "build": "vite build",
    "start": "node server/index.js",
    "worker": "node server/worker.js",
    "dev:worker": "nodemon server/worker.js",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"server/**/*.js\" \"*.{js,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\" \"server/**/*.js\" \"*.{js,json}\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "googleapis": "^171.4.0",
    "heic2any": "^0.0.4",
    "jsonwebtoken": "^9.0.3",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.11.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.12.0",
    "sharp": "^0.34.5",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "vite": "^5.4.0"
  }
}
