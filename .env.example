DATABASE_URL=
GENIE_SUPABASE_SERVICE_KEY=
GENIE_SUPABASE_URL=
PORT=
SUPABASE_SERVICE_KEY=
SUPABASE_URL=
VITE_ANTHROPIC_KEY=
VITE_DEEPGRAM_KEY=
VITE_OPENAI_KEY=
# Browser Supabase client (Realtime Lab/Reception inboxes). Anon key only.
VITE_GENIE_SUPABASE_URL=
VITE_GENIE_SUPABASE_ANON_KEY=

# Google Sheets API credentials (for reading appointments)
# On Railway: Set this as an environment variable with the full JSON content
# Locally: Place gini-ai-8fc66116e12e.json in the server directory (already .gitignored)
GOOGLE_CREDENTIALS=        # (Optional on local dev - uses file if not set) JSON service account key

# HealthRay walking appointment sync
HEALTHRAY_MOBILE=          # Login mobile number
HEALTHRAY_PASSWORD=        # Encrypted password (from browser network tab)
HEALTHRAY_CAPTCHA=         # Captcha token (from browser network tab)
HEALTHRAY_ORG_ID=1528      # Organization ID

# Static-IP egress proxy — the PERMANENT fix for the recurring HealthRay WAF
# 403 IP-block. Set to a fixed-IP forward proxy (e.g. QuotaGuard Static / Fixie /
# a VPS with a reserved IP) and ask HealthRay to allowlist that IP on their WAF.
# When set, ALL HealthRay + Lab traffic exits through it. Format:
#   http://user:pass@proxy-host:port   (https:// also supported)
# Leave blank to use the normal egress (current behaviour).
HEALTHRAY_PROXY_URL=

# ── Lab (labapi.healthray.com) — separate system from node.healthray.com ─────
# Auth (JWT, auto-refreshed on 401). See server/services/lab/labHealthrayApi.js.
LAB_HEALTHRAY_MOBILE=         # Login mobile number
LAB_HEALTHRAY_PASSWORD=       # Login password
LAB_HEALTHRAY_COUNTRY_CODE=+91
LAB_HEALTHRAY_DEVICE_TOKEN=   # Fixed per device (Firebase push token) — never changes
LAB_HEALTHRAY_USER_ID=        # Lab admin user id for read-only API calls
LAB_HEALTHRAY_AUTH_TOKEN=     # Optional seed token (refreshed automatically)
LAB_HEALTHRAY_ACCESS_TOKEN=   # Optional seed token (refreshed automatically)

# Outbound rate limiter — smooths bursts so the server IP isn't WAF 403-blocked.
# Defaults are gentle (strictly serial). Raise only once the egress IP is
# allowlisted by HealthRay (i.e. HEALTHRAY_PROXY_URL is set).
LAB_HEALTHRAY_MAX_RPS=2
LAB_HEALTHRAY_MAX_CONCURRENT=1
LAB_PUPPETEER_CONCURRENCY=1   # Concurrent PDF (report) renders; HealthRay serialises these

# Lab cron loop cadences (ms) — how long the continuous lab loops sleep between
# runs. Longer = fewer requests to labapi from the server IP = far less WAF
# 403-blocking while there's no static-IP proxy. Defaults: lab sync 120–180s,
# partial-results retry 180–240s. Lower only if you have proxy/allowlist headroom.
LAB_LOOP_MIN_BREAK_MS=120000
LAB_LOOP_MAX_BREAK_MS=180000
PARTIAL_LOOP_MIN_BREAK_MS=180000
PARTIAL_LOOP_MAX_BREAK_MS=240000

# Dr. Gini AI — `call_clinic` tool surfaces this phone + name as an inline
# tappable card in the patient chat. Resolved server-side at request time so
# the LLM can never fabricate digits.
HOSPITAL_PHONE=            # e.g. +918050000000
HOSPITAL_NAME=Gini Health  # Clinic display name shown on the card
